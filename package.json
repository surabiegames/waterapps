{
  "name": "tirtawening-wp5",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "pnpm --filter @repo/database exec prisma generate",
    "db:migrate": "pnpm --filter @repo/database exec prisma migrate dev",
    "db:studio": "pnpm --filter @repo/database exec prisma studio",
    "db:seed": "pnpm --filter @repo/database exec prisma db seed",
    "db:import-catering": "pnpm --filter @repo/database run import:catering-csv",
    "db:import-survei": "pnpm --filter @repo/database run import:survei-xlsx",
    "db:stats": "pnpm --filter @repo/database run stats",
    "db:auto-map-points": "pnpm --filter @repo/database run scatter:customers",
    "db:clear-non-survey-geo": "pnpm --filter @repo/database run clear:non-survey-geo",
    "spatial:inspect": "pnpm --filter @repo/database run spatial:inspect",
    "spatial:import-titik": "pnpm --filter @repo/database run spatial:import-titik",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.5.8",
    "typescript": "^5.9.3"
  }
}
