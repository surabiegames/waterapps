DATABASE_URL="postgresql://postgres:postgres@localhost:55432/tirtawening_wp5?schema=public"

# PostGIS: `pnpm docker:up` lalu `pnpm db:migrate` (Docker: postgis/postgis lihat docker-compose.yml).
# Tanpa Docker: PostgreSQL lokal harus punya paket PostGIS (Stack Builder EDB, dll.).
#
# Impor survei Excel WP5 titik+lokasi pelanggan: `pnpm db:import-survei` (berkas di folder `Data/`, nama default di skrip — atau IMPORT_XLSX_PATH).
